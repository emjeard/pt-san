# Canonical site URL (www preferred)
VITE_SITE_URL=https://www.sansolution.tech

# Contact form POST endpoint (Formspree, Getform, or custom API)
# Example Formspree: https://formspree.io/f/xxxxxxxx
VITE_CONTACT_ENDPOINT=

# Fallback / display email (must be a real configured mailbox)
VITE_CONTACT_EMAIL=support@sansolution.tech

# WhatsApp Business number in international format without +
# Example: 628568862327
VITE_WHATSAPP_NUMBER=628568862327

# Google Analytics 4 measurement ID (optional)
# Example: G-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID=
