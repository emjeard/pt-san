# Canonical site URL (www preferred)
VITE_SITE_URL=https://www.sansolution.tech

# Contact form POST endpoint (defaults to /api/contact → Resend)
VITE_CONTACT_ENDPOINT=/api/contact

# Display / mailto email
VITE_CONTACT_EMAIL=kontak@sansolution.tech

# WhatsApp Business number in international format without +
# Example: 628568862327
VITE_WHATSAPP_NUMBER=628568862327

# Google Analytics 4 measurement ID (optional)
# Example: G-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID=

# --- Server-only (Netlify / Vite contact middleware). Never expose with VITE_ prefix. ---

# Resend API key from https://resend.com/api-keys
RESEND_API_KEY=re_4DShiSFJ_GSERFVyhV8hBVZK5vjFbA1vZ

# Inbox that receives form submissions
CONTACT_TO_EMAIL=kontak@sansolution.tech

# Verified sender on the sansolution.tech domain in Resend
# Example: SAN Solution <kontak@sansolution.tech>
# Or: SAN Solution <noreply@sansolution.tech>
RESEND_FROM_EMAIL=SAN Solution <kontak@sansolution.tech>
